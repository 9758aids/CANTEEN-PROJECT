<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>P.T.lee CNCET Canteen - Quick Payment System</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #000000;
            color: #ffffff;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* --- Base Styles --- */
        .toast {
            background: #111111;
            border: 2px solid #333333;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.8);
            animation: slideIn 0.3s ease-out;
            position: relative;
            overflow: hidden;
            margin-bottom: 10px;
            color: #fff;
        }
        .toast::before { content: ''; position: absolute; left: 0; top: 0; height: 100%; width: 4px; }
        .toast.success::before { background: #00ff00; }
        .toast.error::before { background: #ff4444; }
        .toast.info::before { background: #00aaff; }
        @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        
        .live-ticker {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: #0a0a0a;
            border-top: 2px solid #333333;
            padding: 10px 0;
            overflow: hidden;
            z-index: 100;
        }
        .ticker-content { display: flex; animation: scroll 30s linear infinite; white-space: nowrap; }
        @keyframes scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
        .ticker-item { display: inline-flex; align-items: center; padding: 0 30px; color: #888888; font-size: 14px; }

        .sound-toggle {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #1a1a1a;
            border: 2px solid #333333;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 200;
            transition: all 0.3s;
        }
        .sound-toggle:hover { border-color: #ffffff; transform: scale(1.1); }

        /* --- Selection Screen Styles --- */
        .selection-container {
            display: flex; justify-content: center; align-items: center; min-height: 100vh; 
            background: linear-gradient(135deg, #000000 0%, #1a1a1a 100%);
            flex-direction: column;
        }
        .selection-box {
            background: #111111; padding: 40px; border-radius: 15px; border: 2px solid #333333; 
            width: 400px; text-align: center;
        }
        .db-btn {
            display: block; width: 100%; padding: 20px; margin-bottom: 15px;
            background: #1a1a1a; color: #fff; border: 2px solid #333333;
            border-radius: 10px; cursor: pointer; text-align: left;
            transition: all 0.3s; opacity: 0; transform: translateY(-50px);
        }
        .db-btn:last-child { margin-bottom: 0; }
        .db-btn:hover { background: #222; border-color: #00ff00; transform: translateY(-2px); }
        .db-btn h3 { font-size: 18px; margin-bottom: 5px; color: #00ff00; }
        .db-btn p { font-size: 12px; color: #888; }

        /* Falling Animation */
        @keyframes fallIn {
            0% { opacity: 0; transform: translateY(-100px); }
            70% { transform: translateY(10px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        .fall-card { animation: fallIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
        .fall-card:nth-child(1) { animation-delay: 0.1s; }
        .fall-card:nth-child(2) { animation-delay: 0.3s; }

        .login-container { display: flex; justify-content: center; align-items: center; min-height: 100vh; background: linear-gradient(135deg, #000000 0%, #1a1a1a 100%); }
        .login-box { background: #111111; padding: 40px; border-radius: 15px; border: 2px solid #333333; width: 400px; text-align: center; }
        .input-group { margin-bottom: 20px; text-align: left; }
        .input-group label { display: block; margin-bottom: 8px; color: #cccccc; font-size: 14px; text-transform: uppercase; }
        .input-group input, .input-group select { width: 100%; padding: 12px; background: #000000; border: 1px solid #444444; border-radius: 8px; color: #ffffff; font-size: 16px; transition: border-color 0.3s; }
        .input-group input:focus, .input-group select:focus { border-color: #00aaff; outline: none; }
        
        .btn { width: 100%; padding: 15px; background: #ffffff; color: #000000; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer; text-transform: uppercase; transition: all 0.3s; }
        .btn:hover { background: #cccccc; transform: translateY(-2px); }
        .btn:disabled { background: #555; color: #aaa; cursor: not-allowed; transform: none; }
        .btn-secondary { background: #333; color: #fff; border: 1px solid #555; margin-top: 10px; }
        
        /* Split Button Layout */
        .btn-row { display: flex; gap: 10px; margin-top: 25px; }
        .btn-row .btn { flex: 1; margin: 0; }
        .btn-accent { background: #ff4444; color: #fff; }
        .btn-accent:hover { background: #cc3333; }
        .btn-outline { background: transparent; border: 2px solid #444; color: #fff; }
        .btn-outline:hover { background: #222; border-color: #fff; }

        .dashboard { display: none; min-height: 100vh; background: #000000; padding-bottom: 60px; }
        .header {
            background: #111111;
            padding: 15px 20px;
            border-bottom: 2px solid #333333;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .header h1 { font-size: 20px; text-transform: uppercase; letter-spacing: 2px; }
        .user-info { display: flex; align-items: center; gap: 15px; }
        .user-info span { color: #888888; font-size: 14px; }
        .logout-btn { padding: 8px 15px; background: #333333; color: #ffffff; border: 1px solid #555555; border-radius: 5px; cursor: pointer; }
        
        .lang-selector { background: #000; color: #fff; border: 1px solid #444; padding: 5px 10px; border-radius: 5px; cursor: pointer; }

        .balance-section { background: linear-gradient(135deg, #1a1a1a 0%, #000000 100%); padding: 40px; text-align: center; border-bottom: 2px solid #333333; }
        .balance-label { font-size: 14px; color: #888888; text-transform: uppercase; letter-spacing: 3px; margin-bottom: 10px; }
        .balance-amount { font-size: 72px; font-weight: bold; color: #ffffff; text-shadow: 0 0 20px rgba(255, 255, 255, 0.3); }
        .balance-amount.negative { color: #ff4444; }

        .nav-menu { display: flex; justify-content: center; gap: 20px; padding: 30px; background: #0a0a0a; flex-wrap: wrap; }
        .nav-btn { padding: 15px 30px; background: #1a1a1a; color: #ffffff; border: 2px solid #333333; border-radius: 10px; cursor: pointer; font-size: 14px; transition: all 0.3s; }
        .nav-btn:hover { background: #333333; border-color: #ffffff; }
        .nav-btn.active { background: #ffffff; color: #000000; border-color: #ffffff; }

        .page-section { display: none; padding: 40px; max-width: 1200px; margin: 0 auto; animation: fadeIn 0.5s; }
        .page-section.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .section-title { font-size: 32px; margin-bottom: 30px; text-transform: uppercase; border-bottom: 2px solid #333333; padding-bottom: 15px; }

        /* --- Container Styles --- */
        .deposit-container, .withdraw-container { 
            background: #111111; padding: 40px; border-radius: 15px; border: 2px solid #333333; 
            text-align: center; margin-bottom: 30px; max-width: 500px; margin-left: auto; margin-right: auto; 
        }
        
        .upi-pay-btn { background: linear-gradient(135deg, #5f259f, #9c27b0); color: white; border: none; display: flex; align-items: center; justify-content: center; gap: 10px; }
        .upi-pay-btn:hover { background: linear-gradient(135deg, #4a1d7a, #7b1f8a); transform: translateY(-2px); }

        /* Timer Style */
        #depositTimer { 
            margin-top: 20px; font-size: 24px; color: #00aaff; 
            background: #002233; padding: 10px; border-radius: 8px; 
            border: 1px solid #00aaff;
        }

        .transaction-list { background: #111111; border-radius: 15px; border: 2px solid #333333; overflow: hidden; }
        .transaction-item { display: flex; justify-content: space-between; align-items: center; padding: 20px; border-bottom: 1px solid #222222; cursor: pointer; }
        .transaction-item:hover { background: #1a1a1a; }
        .transaction-type { font-size: 12px; text-transform: uppercase; padding: 5px 10px; border-radius: 5px; display: inline-block; }
        .transaction-type.deposit { background: #004400; color: #00ff00; }
        .transaction-type.withdraw { background: #440000; color: #ff4444; }
        
        /* --- Bill Modal Styles --- */
        .bill-modal {
            display: none; 
            position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; 
            background-color: rgba(0,0,0,0.9); 
            justify-content: center; align-items: center;
        }
        .bill-content {
            background: #fff; color: #000; padding: 40px; border-radius: 10px;
            width: 320px; text-align: center; font-family: 'Courier New', Courier, monospace;
            box-shadow: 0 0 50px rgba(255, 255, 255, 0.1);
            position: relative;
        }
        .bill-header { border-bottom: 1px dashed #ccc; margin-bottom: 20px; padding-bottom: 10px; }
        .bill-items { text-align: left; border-bottom: 1px dashed #ccc; margin-bottom: 20px; padding-bottom: 10px; }
        .bill-row { display: flex; justify-content: space-between; margin-bottom: 5px; }
        .bill-total { font-weight: bold; font-size: 18px; margin-bottom: 20px; }

        /* AI Assistant Styles */
        .ai-toggle-btn {
            position: fixed; bottom: 80px; right: 20px; width: 50px; height: 50px;
            background: linear-gradient(135deg, #00aaff, #00ff00); border-radius: 50%; border: none; cursor: pointer;
            display: flex; align-items: center; justify-content: center; font-size: 24px; color: #000;
            box-shadow: 0 5px 15px rgba(0, 170, 255, 0.4); z-index: 200; transition: transform 0.3s;
        }
        .ai-toggle-btn:hover { transform: scale(1.1); }
        .ai-chat-widget {
            position: fixed; bottom: 150px; right: 20px; width: 350px; height: 500px;
            background: #111111; border: 2px solid #00aaff; border-radius: 15px; display: none; flex-direction: column;
            z-index: 200; box-shadow: 0 10px 30px rgba(0, 170, 255, 0.2); overflow: hidden;
        }
        .ai-chat-widget.active { display: flex; }
        .ai-chat-header { background: #0a0a0a; padding: 15px; border-bottom: 1px solid #333; display: flex; justify-content: space-between; align-items: center; }
        .ai-chat-body { flex: 1; padding: 15px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; }
        .chat-message { max-width: 80%; padding: 10px 15px; border-radius: 15px; font-size: 14px; line-height: 1.4; }
        .chat-message.bot { background: #1a1a1a; border: 1px solid #333; align-self: flex-start; }
        .chat-message.user { background: #00aaff; color: #000; align-self: flex-end; }
        .ai-chat-input-area { padding: 15px; border-top: 1px solid #333; display: flex; gap: 10px; }
        .ai-chat-input { flex: 1; padding: 10px; background: #000; border: 1px solid #444; border-radius: 5px; color: #fff; }

        .error-msg { color: #ff4444; font-size: 12px; margin-top: 5px; display: none; text-align: center; }

        /* Print specific styles */
        @media print {
            body * { visibility: hidden; }
            .bill-modal, .bill-modal * { visibility: visible; }
            .bill-modal { position: absolute; left: 0; top: 0; background: white; width: 100%; height: 100%; display: flex; }
            .bill-content { border: 1px solid #000; width: 80%; max-width: 300px; margin: auto; box-shadow: none; }
            .bill-content button { display: none; }
        }

        @media (max-width: 768px) {
            .balance-amount { font-size: 48px; }
            .ai-toggle-btn { bottom: 80px; right: 10px; }
            .sound-toggle { bottom: 20px; right: 10px; }
            .ai-chat-widget { width: 95%; height: 50%; bottom: 140px; right: 2.5%; }
            .header { flex-direction: column; gap: 10px; }
            .user-info { flex-wrap: wrap; justify-content: center; }
            .selection-box { width: 95%; padding: 20px; }
            .bill-content { width: 90%; padding: 20px; }
            .btn-row { flex-direction: column; }
        }
    </style>
</head>
<body>
    <!-- Status Bar -->
    <div class="toast-container" id="toastContainer" style="position: fixed; top: 20px; right: 20px; z-index: 2000;"></div>
    
    <!-- Sound Control -->
    <div class="sound-toggle" id="soundToggle" onclick="toggleSound()" title="Toggle Sound">
        <span id="soundIcon">🔊</span>
    </div>
    <button class="ai-toggle-btn" id="aiToggleBtn" onclick="toggleChat()">🤖</button>

    <!-- Bill Modal -->
    <div id="billModal" class="bill-modal">
        <div class="bill-content">
            <div class="bill-header">
                <h2>P.T.lee CNCET</h2>
                <p style="font-size: 12px;">Canteen Receipt</p>
                <p style="font-size: 10px; margin-top: 5px;" id="billDate"></p>
            </div>
            <div style="text-align: left; margin-bottom: 10px;">
                <p style="font-size: 12px;"><strong>User:</strong> <span id="billUser">-</span></p>
                <p style="font-size: 12px;"><strong>ID:</strong> <span id="billId">-</span></p>
            </div>
            <div class="bill-items" id="billItemsList"></div>
            <div class="bill-total">
                <div class="bill-row"><span>TOTAL:</span><span id="billTotalAmount">₹0</span></div>
            </div>
            <button class="btn" style="background: #333; color: #fff;" onclick="closeBillModal()">Cancel</button>
            <button class="btn" style="background: #00ff00; color: #000; margin-top: 10px;" onclick="finalizePayment()">Confirm & Pay</button>
            <button class="btn" style="background: #fff; color: #000; border: 1px solid #000; margin-top: 10px;" onclick="printReceipt()">Print Receipt</button>
        </div>
    </div>

    <!-- 1. DATABASE SELECTION SCREEN -->
    <div id="selectionScreen" class="selection-container">
        <div class="selection-box">
            <h1 style="margin-bottom: 10px;">P.T.lee CNCET</h1>
            <h2 style="font-size: 16px; color: #888; margin-bottom: 30px;">Select Your Canteen Branch</h2>
            
            <div class="db-btn fall-card" onclick="selectDatabase('main_canteen')">
                <h3>Main Canteen</h3>
                <p>Central Campus - Default Branch</p>
            </div>
            
            <div class="db-btn fall-card" onclick="selectDatabase('north_canteen')">
                <h3>North Campus Canteen</h3>
                <p>Engineering Block Branch</p>
            </div>
        </div>
    </div>

    <!-- 2. LOGIN PAGE -->
    <div id="loginPage" class="login-container" style="display: none;">
        <div class="login-box">
            <h1>P.T.lee CNCET</h1>
            <h2 id="loginSubtitle">Canteen Quick Payment System</h2>
            <form id="loginForm" onsubmit="return handleLogin(event)">
                <div class="input-group">
                    <label>Student Name</label>
                    <input type="text" id="loginName" placeholder="Enter your full name" required>
                </div>
                <div class="input-group">
                    <label>Register Number</label>
                    <input type="text" id="loginRoll" placeholder="e.g. 2026001" required>
                </div>
                <div class="input-group">
                    <label>Password</label>
                    <input type="password" id="loginPass" placeholder="Enter your Password" required>
                    <div id="loginError" class="error-msg">Invalid Name, Register Number or Password (Hint: Password is Roll No)</div>
                </div>
                <button type="submit" class="btn">Login</button>
            </form>
            <button class="btn btn-secondary" onclick="showSelection()">Change Branch</button>
        </div>
    </div>

    <!-- 3. MAIN DASHBOARD -->
    <div id="dashboard" class="dashboard">
        <div class="header">
            <h1 id="headerTitle">Quick Payment System</h1>
            <div class="user-info">
                <select id="langSelector" class="lang-selector" onchange="changeLanguage(this.value)">
                    <option value="en">English</option>
                    <option value="ta">தமிழ்</option>
                    <option value="hi">हिन्दी</option>
                </select>
                <span id="displayName">Student Name</span>
                <span>|</span>
                <span id="displayRoll">Roll No</span>
                <button class="logout-btn" onclick="logout()">Logout</button>
            </div>
        </div>

        <div class="balance-section">
            <div class="balance-label">Current Balance</div>
            <div id="balanceAmount" class="balance-amount">₹0.00</div>
        </div>

        <div class="nav-menu">
            <button class="nav-btn active" onclick="showPage('home')">Dashboard</button>
            <button class="nav-btn" onclick="showPage('deposit')">Deposit</button>
            <button class="nav-btn" onclick="showPage('withdraw')">Withdraw</button>
            <button class="nav-btn" onclick="showPage('history')">History</button>
        </div>

        <!-- Home Page -->
        <div id="home" class="page-section active">
            <h2 class="section-title">Student Dashboard</h2>
            <div style="background: #1a1a1a; padding: 20px; border-radius: 10px; border: 1px solid #333;">
                <h3>Student Information</h3>
                <p><strong>Branch:</strong> <span id="homeBranch" style="color: #00ff00;">-</span></p>
                <p><strong>Name</strong>: <span id="homeName">-</span></p>
                <p><strong>Roll No</strong>: <span id="homeRoll">-</span></p>
                <p><strong>User ID:</strong> <span id="userId">-</span></p>
                <p><strong>Phone:</strong> <span id="homePhone">-</span></p>
                <p><strong>Email:</strong> <span id="homeEmail">-</span></p>
            </div>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 30px;">
                <div style="text-align: center; background: #1a1a1a; padding: 20px; border-radius: 10px;">
                    <h3 style="color: #00ff00; font-size: 32px;" id="totalDeposits">₹0</h3>
                    <p>Total Deposited</p>
                </div>
                <div style="text-align: center; background: #1a1a1a; padding: 20px; border-radius: 10px;">
                    <h3 style="color: #ff4444; font-size: 32px;" id="totalWithdrawals">₹0</h3>
                    <p>Total Spent</p>
                </div>
            </div>
        </div>

        <!-- Deposit Page -->
        <div id="deposit" class="page-section">
            <h2 class="section-title">Deposit Money</h2>
            <div class="deposit-container">
                <h3 style="margin-bottom: 20px;">Add Money via UPI</h3>
                
                <div style="margin-top: 20px; max-width: 300px; margin-left: auto; margin-right: auto;">
                    <label style="display:block; text-align:left; margin-bottom:5px; color:#aaa;">Enter Amount (₹)</label>
                    <input type="number" id="upiAmount" placeholder="e.g. 100" style="width:100%; padding:10px; background:#000; border:1px solid #444; color:#fff; border-radius:5px; text-align:center; font-size:20px;">
                </div>

                <div style="margin-top: 25px; background: #000; padding: 15px; border-radius: 8px; border: 1px solid #333; display: inline-block;">
                    <p style="font-size: 12px; color: #888;">Pay to UPI ID:</p>
                    <p style="font-size: 18px; font-weight: bold; color: #00ff00; letter-spacing: 1px;">9758maran@oksbi</p>
                </div>

                <!-- UPI Button -->
                <button id="upiPayBtn" class="btn upi-pay-btn" style="margin-top: 25px;" onclick="triggerUPIPayment()">
                    <span>📱</span> <span>Pay via GPay / UPI App</span>
                </button>

                <!-- Timer Display (Hidden by default) -->
                <div id="depositTimer" style="display: none;">
                    Please complete payment in <span id="timerCountdown">2:00</span>
                </div>

                <!-- Confirm Button (Hidden by default initially, logic controlled by JS) -->
                <div id="confirmPaymentSection" style="display: none; margin-top: 20px; padding-top: 20px; border-top: 1px solid #333;">
                    <p style="font-size: 12px; color: #888; margin-bottom: 10px;">Payment window closed. Click below if you paid.</p>
                    <button class="btn" style="background: #00ff00; color: #000;" onclick="confirmDeposit()">
                        <span>✓</span> <span>I've Made the Payment</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Withdraw Page -->
        <div id="withdraw" class="page-section">
            <h2 class="section-title"><span>Withdraw / Pay</span></h2>
            
            <div class="withdraw-container">
                <h3 style="margin-bottom: 20px; color: #ff4444;">Payment Entry</h3>
                
                <div style="max-width: 300px; margin: 0 auto 20px; text-align: left;">
                    <div class="input-group" style="margin-bottom: 0;">
                        <label>Description</label>
                        <select id="itemSelect" style="border-color: #444;">
                            <option value="Tea">Tea</option>
                            <option value="Coffee">Coffee</option>
                            <option value="Chicken Puff">Chicken Puff</option>
                            <option value="Veg Puff">Veg Puff</option>
                            <option value="Egg Puff">Egg Puff</option>
                            <option value="Others">Others</option>
                        </select>
                    </div>
                </div>

                <div style="max-width: 300px; margin: 0 auto; text-align: left;">
                    <div class="input-group" style="margin-bottom: 0;">
                        <label>Amount (₹)</label>
                        <input type="number" id="withdrawAmount" placeholder="e.g. 50" style="border-color: #ff4444;">
                    </div>
                </div>

                <div class="btn-row">
                    <button class="btn btn-accent" onclick="deductImmediate()">Deduct Balance</button>
                    <button class="btn btn-outline" onclick="generateBill()">Generate Bill</button>
                </div>
            </div>
        </div>

        <!-- History Page -->
        <div id="history" class="page-section">
            <h2 class="section-title">Transaction History</h2>
            <div id="transactionList" class="transaction-list"></div>
        </div>
    </div>

    <!-- AI Chat Widget -->
    <div class="ai-chat-widget" id="aiChatWidget">
        <div class="ai-chat-header">
            <h3>🤖 <span>AI Assistant</span></h3>
            <button onclick="toggleChat()" style="background: none; border: none; color: #fff; font-size: 20px; cursor: pointer;">&times;</button>
        </div>
        <div class="ai-chat-body" id="chatBody">
            <div class="chat-message bot">Hello! How can I help you?</div>
        </div>
        <div class="ai-chat-input-area">
            <input type="text" id="chatInput" class="ai-chat-input" placeholder="Type a message..." onkeypress="if(event.key==='Enter')sendChat()">
            <button class="btn" style="width: auto; padding: 10px 15px;" onclick="sendChat()">Send</button>
        </div>
    </div>

    <div class="live-ticker" id="liveTicker">
        <div class="ticker-content">
            <span class="ticker-item">Welcome to P.T.Lee CNCET Canteen</span>
            <span class="ticker-item">UPI ID: 9758maran@oksbi</span>
            <span class="ticker-item">Fast and Secure Payments</span>
            <span class="ticker-item">Welcome to P.T.Lee CNCET Canteen</span>
            <span class="ticker-item">UPI ID: 9758maran@oksbi</span>
            <span class="ticker-item">Fast and Secure Payments</span>
        </div>
    </div>

    <script>
        // --- DATABASE CONFIGURATION ---
        const databases = {
            'main_canteen': {
                name: "Main Canteen",

        function changeLanguage(lang) {
            currentLang = lang;
            document.querySelectorAll('[data-lang]').forEach(el => {
                const key = el.getAttribute('data-lang');
                if (translations[lang][key]) el.textContent = translations[lang][key];
            });
        }

        // --- Sound System ---
        function playSound(type) {
            if (!soundEnabled) return;
            if (audioContext.state === 'suspended') audioContext.resume();
            const o = audioContext.createOscillator();
            const g = audioContext.createGain();
            o.connect(g); g.connect(audioContext.destination);
            if (type === 'success') {
                o.frequency.setValueAtTime(600, audioContext.currentTime);
                o.frequency.setValueAtTime(800, audioContext.currentTime + 0.1);
            } else {
                o.frequency.setValueAtTime(200, audioContext.currentTime);
            }
            g.gain.setValueAtTime(0.3, audioContext.currentTime);
            g.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.3);
            o.start(); o.stop(audioContext.currentTime + 0.3);
        }
        function toggleSound() {
            soundEnabled = !soundEnabled;
            document.getElementById('soundIcon').textContent = soundEnabled ? '🔊' : '🔇';
        }

        // --- Initialization ---
        document.addEventListener('DOMContentLoaded', function() {
            showSelection();
        });

        // --- View Management ---
        function showSelection() {
            document.getElementById('selectionScreen').style.display = 'flex';
            document.getElementById('loginPage').style.display = 'none';
            document.getElementById('dashboard').style.display = 'none';
        }

        function selectDatabase(dbKey) {
            currentDb = databases[dbKey];
            document.getElementById('selectionScreen').style.display = 'none';
            document.getElementById('loginPage').style.display = 'flex';
            document.getElementById('loginSubtitle').textContent = currentDb.name + " - Login";
            document.getElementById('loginError').style.display = 'none';
        }

        // --- Login Logic ---
        function handleLogin(e) {
            e.preventDefault();
            
            const nameInput = document.getElementById('loginName').value.trim().toLowerCase();
            const rollInput = document.getElementById('loginRoll').value.trim();
            const passInput = document.getElementById('loginPass').value; 
            const errorDiv = document.getElementById('loginError');

            const student = currentDb.students.find(s => 
                s.roll === rollInput && 
                s.name.toLowerCase() === nameInput
            );

            if (student && passInput === student.roll) {
                errorDiv.style.display = 'none';
                loginSuccess(student);
            } else {
                errorDiv.style.display = 'block';
                playSound('error');
            }
            return false;
        }

        function loginSuccess(studentData) {
            currentUser = { 
                name: studentData.name, 
                roll: studentData.roll, 
                phone: studentData.phone, 
                email: studentData.email, 
                userId: studentData.roll 
            };
            
            loadUserData();

            document.getElementById('headerTitle').textContent = currentDb.name;
            document.getElementById('homeBranch').textContent = currentDb.name;
            document.getElementById('displayName').textContent = currentUser.name;
            document.getElementById('displayRoll').textContent = currentUser.roll;
            document.getElementById('homeName').textContent = currentUser.name;
            document.getElementById('homeRoll').textContent = currentUser.roll;
            document.getElementById('userId').textContent = currentUser.userId;
            document.getElementById('homePhone').textContent = currentUser.phone;
            document.getElementById('homeEmail').textContent = currentUser.email;
            
            document.getElementById('loginPage').style.display = 'none';
            document.getElementById('dashboard').style.display = 'block';
            
            updateBalance();
            updateStats();
            playSound('success');
            showToast(translations[currentLang].toast_welcome, `Welcome ${currentUser.name}`, 'success');
        }

        function logout() {
            currentUser = null;
            transactions = [];
            balance = 0;
            document.getElementById('loginPage').style.display = 'flex';
            document.getElementById('dashboard').style.display = 'none';
            document.getElementById('loginName').value = '';
            document.getElementById('loginRoll').value = '';
            document.getElementById('loginPass').value = '';
        }

        // --- Navigation & UI ---
        function showPage(pageName) {
            // Reset deposit UI if navigating away
            if (pageName !== 'deposit') {
                resetDepositUI();
            }

            document.querySelectorAll('.page-section').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(pageName).classList.add('active');
            
            const btn = document.querySelector(`.nav-btn[onclick="showPage('${pageName}')"]`);
            if(btn) btn.classList.add('active');

            if (pageName === 'history') renderTransactionHistory();
        }

        // --- Deposit Logic ---

        function triggerUPIPayment() {
            const amountInput = document.getElementById('upiAmount');
            const amount = Math.round(parseFloat(amountInput.value) * 100) / 100;
            
            if (!amount || amount <= 0) {
                showToast('Error', 'Please enter a valid amount', 'error');
                playSound('error');
                return;
            }

            // 1. Store the pending amount
            pendingDepositAmount = amount;

            // 2. Trigger UPI App
            const upiId = '9758maran@oksbi'; 
            const payeeName = 'P.T.lee CNCET';
            let upiLink = `upi://pay?pa=${upiId}&pn=${encodeURIComponent(payeeName)}&am=${amount}`;
            window.location.href = upiLink;

            // 3. Lock UI
            amountInput.disabled = true;
            document.getElementById('upiPayBtn').disabled = true;
            
            // 4. Hide Confirm button (if visible) and Show Timer
            document.getElementById('confirmPaymentSection').style.display = 'none';
            document.getElementById('depositTimer').style.display = 'block';

            // 5. Start 2-minute countdown
            startDepositTimer(120); 
        }

        function startDepositTimer(duration) {
            let timer = duration, minutes, seconds;
            const display = document.getElementById('timerCountdown');
            
            // Clear existing timer if any
            if (depositTimerInterval) clearInterval(depositTimerInterval);

            depositTimerInterval = setInterval(function () {
                minutes = parseInt(timer / 60, 10);
                seconds = parseInt(timer % 60, 10);

                minutes = minutes < 10 ? "0" + minutes : minutes;
                seconds = seconds < 10 ? "0" + seconds : seconds;

                display.textContent = minutes + ":" + seconds;

                if (--timer < 0) {
                    clearInterval(depositTimerInterval);
                    onTimerComplete();
                }
            }, 1000);
        }

        function onTimerComplete() {
            // Hide Timer
            document.getElementById('depositTimer').style.display = 'none';
            
            // Show Confirm Button
            document.getElementById('confirmPaymentSection').style.display = 'block';
            showToast('Timer Done', 'Please confirm if payment was successful.', 'info');
        }

        function resetDepositUI() {
            // Clear timer
            if (depositTimerInterval) clearInterval(depositTimerInterval);
            depositTimerInterval = null;
            
            // Reset variables
            pendingDepositAmount = 0;
            
            // Reset UI elements
            const amountInput = document.getElementById('upiAmount');
            amountInput.disabled = false;
            amountInput.value = '';
            document.getElementById('upiPayBtn').disabled = false;
            document.getElementById('depositTimer').style.display = 'none';
            document.getElementById('confirmPaymentSection').style.display = 'none';
        }

        function confirmDeposit() {
            // Use the stored pending amount
            const amount = pendingDepositAmount;

            if (!amount || amount <= 0) {
                showToast('Error', 'Session expired or invalid amount. Please try again.', 'error');
                resetDepositUI();
                return;
            }

            if (!currentUser) {
                showToast('Error', 'User not logged in', 'error');
                return;
            }

            // Add to balance
            balance += amount;

            const transaction = {
                id: Date.now(),
                type: 'deposit',
                amount: amount,
                timestamp: new Date().toLocaleString(),
                userId: currentUser.userId,
                name: currentUser.name,
                note: 'Deposited via UPI'
            };
            transactions.push(transaction);

            saveUserData();
            updateBalance();
            updateStats();

            // Reset UI for next transaction
            resetDepositUI();
            
            playSound('success');
            showToast('Success', `₹${amount.toFixed(2)} added to your balance!`, 'success');
        }

        // --- Withdraw Logic ---
        
        function getWithdrawInputs() {
            const amountInput = document.getElementById('withdrawAmount');
            const itemSelect = document.getElementById('itemSelect');
            const amount = Math.round(parseFloat(amountInput.value) * 100) / 100; 
            const item = itemSelect.value;
            return { amount, item, amountInput };
        }

        function deductImmediate() {
            const { amount, item } = getWithdrawInputs();

            if (!amount || amount <= 0) {
                showToast('Error', 'Please enter a valid amount', 'error');
                playSound('error');
                return;
            }

            if (!currentUser) return;

            if (amount > balance) {
                showToast('Error', 'Insufficient Balance!', 'error');
                playSound('error');
                return;
            }

            balance -= amount;

            const transaction = {
                id: Date.now(),
                type: 'withdraw',
                amount: amount,
                timestamp: new Date().toLocaleString(),
                userId: currentUser.userId,
                name: currentUser.name,
                note: item
            };
            transactions.push(transaction);

            saveUserData();
            updateBalance();
            updateStats();

            document.getElementById('withdrawAmount').value = '';
            
            playSound('success');
            showToast('Success', `₹${amount.toFixed(2)} deducted for ${item}`, 'success');
        }

        function generateBill() {
            const { amount, item } = getWithdrawInputs();

            if (!amount || amount <= 0) {
                showToast('Error', 'Please enter a valid amount', 'error');
                playSound('error');
                return;
            }

            if (!currentUser) return;
            
            currentBillData = { amount, item };

            document.getElementById('billDate').textContent = new Date().toLocaleString();
            document.getElementById('billUser').textContent = currentUser.name;
            document.getElementById('billId').textContent = currentUser.userId;
            document.getElementById('billItemsList').innerHTML = `
                <div class="bill-row"><span>Item:</span><span>${currentBillData.item}</span></div>
                <div class="bill-row"><span>Amount:</span><span>₹${currentBillData.amount.toFixed(2)}</span></div>
            `;
            document.getElementById('billTotalAmount').textContent = '₹' + currentBillData.amount.toFixed(2);

            document.getElementById('billModal').style.display = 'flex';
        }

        function closeBillModal() {
            document.getElementById('billModal').style.display = 'none';
            currentBillData = null;
        }

        function finalizePayment() {
            if (!currentBillData) {
                closeBillModal();
                return;
            }
            
            const { amount, item } = currentBillData;

            if (amount > balance) {
                showToast('Error', 'Insufficient Balance!', 'error');
                playSound('error');
                closeBillModal();
                return;
            }

            balance -= amount;

            const transaction = {
                id: Date.now(),
                type: 'withdraw',
                amount: amount,
                timestamp: new Date().toLocaleString(),
                userId: currentUser.userId,
                name: currentUser.name,
                note: item
            };
            transactions.push(transaction);

            saveUserData();
            updateBalance();
            updateStats();

            document.getElementById('withdrawAmount').value = '';
            closeBillModal();
            
            playSound('success');
            showToast('Success', `Payment for ${item} successful!`, 'success');
        }

        function printReceipt() {
            window.print();
        }

        // --- Data Management ---
        function updateBalance() {
            const el = document.getElementById('balanceAmount');
            el.textContent = '₹' + balance.toFixed(2);
            el.classList.toggle('negative', balance < 0);
        }

        function updateStats() {
            let deposits = 0, withdrawals = 0;
            transactions.forEach(t => t.type === 'deposit' ? deposits += t.amount : withdrawals += t.amount);
            document.getElementById('totalDeposits').textContent = '₹' + deposits.toFixed(0);
            document.getElementById('totalWithdrawals').textContent = '₹' + withdrawals.toFixed(0);
        }

        function renderTransactionHistory() {
            const list = document.getElementById('transactionList');
            list.innerHTML = '';
            if (transactions.length === 0) {
                list.innerHTML = '<div style="padding:40px; text-align:center; color:#666;">No history</div>';
                return;
            }
            [...transactions].reverse().forEach(t => {
                const isDeposit = t.type === 'deposit';
                const item = document.createElement('div');
                item.className = 'transaction-item';
                item.innerHTML = `
                    <div class="transaction-info">
                        <span class="transaction-type ${t.type}">${t.type}</span>
                        <div style="color:#888; font-size:12px; margin-top:4px;">${t.note}</div>
                        <div style="color:#666; font-size:11px;">${t.timestamp}</div>
                    </div>
                    <div style="font-size:18px; font-weight:bold; color:${isDeposit ? '#00ff00' : '#ff4444'}">
                        ${isDeposit ? '+' : '-'}₹${t.amount.toFixed(2)}
                    </div>
                `;
                list.appendChild(item);
            });
        }

        function loadUserData() {
            const dataKey = currentDb.storageKey + "_" + currentUser.userId;
            const stored = localStorage.getItem(dataKey);
            
            balance = 0;
            transactions = [];

            if (stored) {
                const data = JSON.parse(stored);
                balance = data.balance || 0;
                transactions = data.transactions || [];
            }
        }

        function saveUserData() {
            if (!currentUser || !currentDb) return;
            
            const dataKey = currentDb.storageKey + "_" + currentUser.userId;
            
            const data = {
                balance: balance,
                transactions: transactions
            };
            
            localStorage.setItem(dataKey, JSON.stringify(data));
        }

        function showToast(title, message, type) {
            const c = document.getElementById('toastContainer');
            const t = document.createElement('div');
            t.className = `toast ${type}`;
            t.innerHTML = `<div class="toast-header"><span class="toast-title">${title}</span></div><div>${message}</div>`;
            c.appendChild(t);
            setTimeout(() => t.remove(), 3000);
        }

        // --- AI Chat ---
        function toggleChat() { document.getElementById('aiChatWidget').classList.toggle('active'); }
        function sendChat() {
            const input = document.getElementById('chatInput');
            if (!input.value.trim()) return;
            addChatMessage(input.value, 'user');
            input.value = '';
            setTimeout(() => addChatMessage("System updated. Balance: ₹" + balance.toFixed(2), 'bot'), 500);
        }
        function addChatMessage(text, sender) {
            const b = document.getElementById('chatBody');
            const d = document.createElement('div');
            d.className = `chat-message ${sender}`;
            d.textContent = text;
            b.appendChild(d);
            b.scrollTop = b.scrollHeight;
        }
    </script>
